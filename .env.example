# ── Application Config ─────────────────────────────────────────────────────
# Copy this file to .env and edit as needed.

# Model name (sentence-transformers). Change to use a different model.
MODEL_NAME=all-MiniLM-L6-v2

# Path to candidate data (relative to project root)
CANDIDATES_PATH=data/candidates.json

# Number of top candidates to return per match request
TOP_K=5

# Server settings
HOST=127.0.0.1
PORT=8000
LOG_LEVEL=info
